[
    {"word": "千峰竟秀", "pinyin": "qiān fēng jìng xiù", "explanation": "无数山峰竞相比美。形容山峰众多，各具特色，争奇斗艳。常用于描写壮丽的山景。"},
    {"word": "疏密有致", "pinyin": "shū mì yǒu zhì", "explanation": "指布局疏密得当，错落有致。形容事物安排得有疏有密，富有节奏感和层次感。常用于评价书画、文章、园林等的布局。"},
    {"word": "熠熠生辉", "pinyin": "yì yì shēng huī", "explanation": "闪耀出光辉。形容光彩闪耀，十分耀眼。常用来形容宝石、眼睛、成就等闪耀着光芒。"},
    {"word": "熠熠闪光", "pinyin": "yì yì shǎn guāng", "explanation": "闪耀着光芒。形容光彩夺目。"},
    {"word": "栩栩如生", "pinyin": "xǔ xǔ rú shēng", "explanation": "栩栩活泼生动的样子。指艺术形象非常逼真，如同活的一样。"},
    {"word": "蔚为壮观", "pinyin": "wèi wéi zhuàng guān", "explanation": "蔚茂盛；壮观壮丽的景象。形容事物美好繁多，形成盛大壮观的景象。"},
    {"word": "气势磅礴", "pinyin": "qì shì páng bó", "explanation": "磅礴广大无边的样子。形容气势雄伟壮大。"},
    {"word": "波澜壮阔", "pinyin": "bō lán zhuàng kuò", "explanation": "原形容水面辽阔。现比喻声势雄壮或规模宏大。"},
    {"word": "荡气回肠", "pinyin": "dàng qì huí cháng", "explanation": "荡动摇动；气回旋。形容文章、乐曲十分婉转动人。也形容情感激荡，十分感人。"},
    {"word": "扣人心弦", "pinyin": "kòu rén xīn xián", "explanation": "扣敲打。形容事物激动人心，使人心情激动。"},
    {"word": "引人瞩目", "pinyin": "yǐn rén zhǔ mù", "explanation": "瞩目注视。引起人们的注意和注视。"},
    {"word": "令人神往", "pinyin": "lìng rén shén wǎng", "explanation": "神往心里向往。使人心里十分向往。"},
    {"word": "叹为观止", "pinyin": "tàn wéi guān zhǐ", "explanation": "叹赞赏；观止看到这里就够了。赞美看到的事物好到了极点。"},
    {"word": "鬼斧神工", "pinyin": "guǐ fǔ shén gōng", "explanation": "像是鬼神制作出来的。形容建筑、雕塑等技艺精巧，非人力所能达到。"},
    {"word": "巧夺天工", "pinyin": "qiǎo duó tiān gōng", "explanation": "夺胜过。人工的精巧胜过天然。形容技艺十分巧妙。"},
    {"word": "出神入化", "pinyin": "chū shén rù huà", "explanation": "神化指超神入妙的地步。形容技艺达到了绝妙的境界。"},
    {"word": "炉火纯青", "pinyin": "lú huǒ chún qīng", "explanation": "纯青相传道家炼丹，到炉火呈现纯青色时就算成功。比喻功夫达到了纯熟完美的境界。"},
    {"word": "登峰造极", "pinyin": "dēng fēng zào jí", "explanation": "登攀登；峰山峰；造到达；极顶点。比喻学问、技能等达到最高的境界或成就。"},
    {"word": "游刃有余", "pinyin": "yóu rèn yǒu yú", "explanation": "刀刃运转于骨节空隙中，有回旋的余地。比喻技术熟练，经验丰富，解决问题毫不费力。"},
    {"word": "挥洒自如", "pinyin": "huī sǎ zì rú", "explanation": "挥洒挥笔洒墨。形容写文章、写字或绘画时笔墨运用自如，不受拘束。也形容做事从容不迫。"},
    {"word": "行云流水", "pinyin": "xíng yún liú shuǐ", "explanation": "形容文章自然不受约束，就像云朵飘动，流水潺潺一样。也形容艺术表演等自然流畅。"},
    {"word": "浑然天成", "pinyin": "hún rán tiān chéng", "explanation": "浑然完整不可分割的样子。形容事物完美自然，没有人工雕琢的痕迹。"},
    {"word": "气韵生动", "pinyin": "qì yùn shēng dòng", "explanation": "指书画作品中描绘的形象具有生动的气度韵致。是中国画的重要审美标准之一。"},
    {"word": "意境深远", "pinyin": "yì jìng shēn yuǎn", "explanation": "指文艺作品或自然景象所营造的意境深邃悠远，耐人寻味。"},
    {"word": "韵味十足", "pinyin": "yùn wèi shí zú", "explanation": "形容情趣、意味非常浓厚。常用于评价艺术作品、表演等富有韵味。"},
    {"word": "别具匠心", "pinyin": "bié jù jiàng xīn", "explanation": "匠心巧妙的心思。指在技巧和艺术方面具有与众不同的巧妙构思。"},
    {"word": "独具慧眼", "pinyin": "dú jù huì yǎn", "explanation": "具有独到的眼光或见解。形容眼光敏锐，能看到别人看不到的东西。"},
    {"word": "高瞻远瞩", "pinyin": "gāo zhān yuǎn zhǔ", "explanation": "瞻视；瞩注视。站得高，看得远。比喻眼光远大。"},
    {"word": "深思熟虑", "pinyin": "shēn sī shú lǜ", "explanation": "反复深入地考虑。"},
    {"word": "深谋远虑", "pinyin": "shēn móu yuǎn lǜ", "explanation": "指计划得很周密，考虑得很长远。"},
    {"word": "运筹帷幄", "pinyin": "yùn chóu wéi wò", "explanation": "运筹筹划；帷幄古代军中帐幕。指在军帐中筹划计策。比喻在后方决定作战策略。"},
    {"word": "胸有成竹", "pinyin": "xiōng yǒu chéng zhú", "explanation": "原指画竹子要在心里有一幅竹子的形象。比喻在做事情之前已经拿定主意。"},
    {"word": "泰然自若", "pinyin": "tài rán zì ruò", "explanation": "泰然安然不以为意的样子。形容在紧急情况下沉着镇定，不慌不乱。"},
    {"word": "从容不迫", "pinyin": "cóng róng bù pò", "explanation": "从容不慌不忙，很镇定；不迫不急促。不慌不忙，沉着镇定。"},
    {"word": "处变不惊", "pinyin": "chǔ biàn bù jīng", "explanation": "面对变故，毫不惊慌。形容人沉着冷静，能从容应对突发情况。"},
    {"word": "临危不惧", "pinyin": "lín wēi bù jù", "explanation": "临遇到；危危险；惧怕。遇到危难的时候，一点也不怕。"},
    {"word": "坚忍不拔", "pinyin": "jiān rěn bù bá", "explanation": "形容信念坚定，意志顽强，不可动摇。"},
    {"word": "锲而不舍", "pinyin": "qiè ér bù shě", "explanation": "锲镂刻；舍停止。不断地镂刻。比喻有恒心，有毅力。"},
    {"word": "孜孜不倦", "pinyin": "zī zī bù juàn", "explanation": "孜孜勤勉的样子。指工作或学习勤奋不知疲倦。"},
    {"word": "废寝忘食", "pinyin": "fèi qǐn wàng shí", "explanation": "废停止。顾不得睡觉，忘记了吃饭。形容非常专心努力。"},
    {"word": "呕心沥血", "pinyin": "ǒu xīn lì xuè", "explanation": "呕吐；沥滴。比喻用尽心思。多形容为事业、工作、文艺创作等用心的艰苦。"},
    {"word": "殚精竭虑", "pinyin": "dān jīng jié lǜ", "explanation": "殚竭尽；虑思虑。形容用尽心思。"},
    {"word": "披荆斩棘", "pinyin": "pī jīng zhǎn jí", "explanation": "劈开丛生多刺的野生植物。比喻在创业过程中或前进道路上清除障碍，克服重重困难。"},
    {"word": "乘风破浪", "pinyin": "chéng fēng pò làng", "explanation": "船只乘着风势破浪前进。比喻排除困难，奋勇前进。"},
    {"word": "继往开来", "pinyin": "jì wǎng kāi lái", "explanation": "继继承；开开辟。继承前人的事业，开辟未来的道路。"},
    {"word": "承前启后", "pinyin": "chéng qián qǐ hòu", "explanation": "承承接；启开创。承接前面的，开创后来的。指继承前人事业，为后人开辟道路。"},
    {"word": "推陈出新", "pinyin": "tuī chén chū xīn", "explanation": "指对旧的文化进行批判地继承，剔除其糟粕，吸取其精华，创造出新的文化。"},
    {"word": "与时俱进", "pinyin": "yǔ shí jù jìn", "explanation": "随着时间的推移而不断发展、前进。"},
    {"word": "日新月异", "pinyin": "rì xīn yuè yì", "explanation": "新更新；异不同。每天都在更新，每月都有变化。指发展或进步迅速，不断出现新事物、新气象。"},
    {"word": "突飞猛进", "pinyin": "tū fēi měng jìn", "explanation": "突猛然。形容进步和发展特别迅速。"},
    {"word": "蒸蒸日上", "pinyin": "zhēng zhēng rì shàng", "explanation": "蒸蒸上升、兴盛的样子。形容事业一天天向上发展。"},
    {"word": "欣欣向荣", "pinyin": "xīn xīn xiàng róng", "explanation": "欣欣草木茂盛的样子。形容草木长得茂盛。比喻事业蓬勃发展。"},
    {"word": "方兴未艾", "pinyin": "fāng xīng wèi ài", "explanation": "方正在；兴兴起；未没有；艾停止。事物正在发展，尚未达到止境。"},
    {"word": "如火如荼", "pinyin": "rú huǒ rú tú", "explanation": "荼茅草的白花。像火那样红，像荼那样白。原比喻军容之盛。现用来形容大规模的行动气势旺盛，气氛热烈。"},
    {"word": "势不可挡", "pinyin": "shì bù kě dǎng", "explanation": "势气势。来势迅猛，不可抵挡。"},
    {"word": "锐不可当", "pinyin": "ruì bù kě dāng", "explanation": "锐锐气；当抵挡。形容勇往直前的气势，不可抵挡。"},
    {"word": "所向披靡", "pinyin": "suǒ xiàng pī mǐ", "explanation": "所向风吹到的地方；披靡草木随风倒伏的样子。比喻力量所到之处，一切障碍皆被扫除。"},
    {"word": "无坚不摧", "pinyin": "wú jiān bù cuī", "explanation": "形容力量非常强大，没有什么坚固的东西不能摧毁。"},
    {"word": "百折不挠", "pinyin": "bǎi zhé bù náo", "explanation": "折挫折；挠弯曲。比喻意志坚强，无论受到多少次挫折，毫不动摇退缩。"},
    {"word": "坚韧不拔", "pinyin": "jiān rèn bù bá", "explanation": "坚坚定；韧柔韧；拔动摇。形容信念坚定，意志顽强，不可动摇。"},
    {"word": "气吞山河", "pinyin": "qì tūn shān hé", "explanation": "气势可以吞没山河。形容气魄很大。"},
    {"word": "叱咤风云", "pinyin": "chì zhà fēng yún", "explanation": "叱咤怒喝声。一声呼喊、怒喝，可以使风云翻腾起来。形容声势威力极大。"},
    {"word": "翻天覆地", "pinyin": "fān tiān fù dì", "explanation": "覆翻过来。形容变化巨大而彻底。也形容闹得很凶。"},
    {"word": "惊天动地", "pinyin": "jīng tiān dòng dì", "explanation": "使天地惊动。形容某个事件的声势或意义极大。"},
    {"word": "震古烁今", "pinyin": "zhèn gǔ shuò jīn", "explanation": "烁发光的样子。震动古人，显耀当世。形容事业或功绩伟大。"},
    {"word": "彪炳史册", "pinyin": "biāo bǐng shǐ cè", "explanation": "彪炳照耀；史册历史典籍。形容伟大的业绩永远记载在史书上。"},
    {"word": "流芳百世", "pinyin": "liú fāng bǎi shì", "explanation": "流流传；芳花草的香气，比喻好名声；百世世代。好名声永远流传后世。"},
    {"word": "名垂青史", "pinyin": "míng chuí qīng shǐ", "explanation": "名名声；垂流传；青史史书。名字及其事迹记载在史书上，流传后世。"},
    {"word": "万古流芳", "pinyin": "wàn gǔ liú fāng", "explanation": "芳香，指美名。好名声永远流传。"},
    {"word": "永垂不朽", "pinyin": "yǒng chuí bù xiǔ", "explanation": "朽腐烂，磨灭。指姓名、事迹、精神等永远流传，不会磨灭。"},
    {"word": "丰功伟绩", "pinyin": "fēng gōng wěi jì", "explanation": "丰大；伟伟大。巨大的功绩和成就。"},
    {"word": "功勋卓著", "pinyin": "gōng xūn zhuó zhù", "explanation": "功勋功劳；卓著突出显著。形容功劳极大，贡献突出。"},
    {"word": "卓尔不群", "pinyin": "zhuó ěr bù qún", "explanation": "卓尔特出的样子；不群与众不同。指才德超出寻常，与众不同。"},
    {"word": "超凡脱俗", "pinyin": "chāo fán tuō sú", "explanation": "超出常人，脱离世俗。形容境界很高，不同凡响。"},
    {"word": "不同凡响", "pinyin": "bù tóng fán xiǎng", "explanation": "凡响平凡的音乐。形容事物不平凡，非常出色。"},
    {"word": "独树一帜", "pinyin": "dú shù yī zhì", "explanation": "树树立；帜旗帜。单独树起一面旗帜。比喻自成一家。"},
    {"word": "标新立异", "pinyin": "biāo xīn lì yì", "explanation": "标提出；新新奇；立建立；异不同。提出新奇的主张，表示与众不同。"},
    {"word": "别开生面", "pinyin": "bié kāi shēng miàn", "explanation": "生面新的面目。原意是凌烟阁中功臣画像本已褪色，经曹霸重新描绘之后才显得有生气。比喻另外创出一种新的形式或局面。"},
    {"word": "耳目一新", "pinyin": "ěr mù yī xīn", "explanation": "听到的、看到的跟以前完全不同，令人感到很新鲜。"},
    {"word": "焕然一新", "pinyin": "huàn rán yī xīn", "explanation": "焕然鲜明光亮的样子。形容出现了崭新的面貌。"},
    {"word": "脱胎换骨", "pinyin": "tuō tāi huàn gǔ", "explanation": "原为道教语。指修道者得道以后，就脱凡胎为圣胎，换凡骨为仙骨。现比喻彻底改变立场观点。"},
    {"word": "沧海桑田", "pinyin": "cāng hǎi sāng tián", "explanation": "桑田农田。大海变成桑田，桑田变成大海。比喻世事变化很大。"},
    {"word": "斗转星移", "pinyin": "dǒu zhuǎn xīng yí", "explanation": "星斗变动位置。指季节或时间的变化。"},
    {"word": "物换星移", "pinyin": "wù huàn xīng yí", "explanation": "物换景物变幻；星移星辰移位。景物改变了，星辰的位置也移动了。比喻时间的变化。"},
    {"word": "瞬息万变", "pinyin": "shùn xī wàn biàn", "explanation": "瞬一眨眼；息呼吸。在极短的时间内变化快而多。"},
    {"word": "气象万千", "pinyin": "qì xiàng wàn qiān", "explanation": "气象情景。形容景象或事物壮丽而多变化。"},
    {"word": "千姿百态", "pinyin": "qiān zī bǎi tài", "explanation": "形容姿态多种多样。"},
    {"word": "多姿多彩", "pinyin": "duō zī duō cǎi", "explanation": "形容颜色形态多样，丰富多彩。"},
    {"word": "五彩缤纷", "pinyin": "wǔ cǎi bīn fēn", "explanation": "五彩各种颜色；缤纷繁多交错的样子。指颜色繁多，非常好看。"},
    {"word": "绚丽多彩", "pinyin": "xuàn lì duō cǎi", "explanation": "形容色彩华丽，种类很多。"},
    {"word": "美不胜收", "pinyin": "měi bù shèng shōu", "explanation": "胜尽。美好的东西很多，一时看不过来。"},
    {"word": "琳琅满目", "pinyin": "lín láng mǎn mù", "explanation": "琳琅精美的玉石。满眼都是珍贵的东西。形容美好的事物很多。"},
    {"word": "目不暇接", "pinyin": "mù bù xiá jiē", "explanation": "暇空闲。东西太多，眼睛看不过来。"},
    {"word": "应接不暇", "pinyin": "yìng jiē bù xiá", "explanation": "暇空闲。原指美景繁多，看不过来。后多形容来人或事情太多，接待应付不过来。"},
    {"word": "交相辉映", "pinyin": "jiāo xiāng huī yìng", "explanation": "各种光芒、色彩等互相映照。常用于形容美好的景象。"},
    {"word": "相得益彰", "pinyin": "xiāng dé yì zhāng", "explanation": "益更加；彰明显。指两个人或两件事物互相配合，双方的能力和作用更能显示出来。"},
    {"word": "珠联璧合", "pinyin": "zhū lián bì hé", "explanation": "珍珠联串在一起，美玉结合在一块。比喻杰出的人才或美好的事物结合在一起。"},
    {"word": "天作之合", "pinyin": "tiān zuò zhī hé", "explanation": "合配合。好像是上天给予安排，很完美的配合。比喻两人感情融洽，婚姻美满。"},
    {"word": "浑然一体", "pinyin": "hún rán yī tǐ", "explanation": "浑然完整不可分割的样子。融合成一个整体。形容完整不可分割。"},
    {"word": "水乳交融", "pinyin": "shuǐ rǔ jiāo róng", "explanation": "交融融合在一起。像水和牛奶融合在一起。比喻关系非常融洽或结合十分紧密。"},
    {"word": "相辅相成", "pinyin": "xiāng fǔ xiāng chéng", "explanation": "辅辅助。指两件事物互相配合，互相补充，缺一不可。"},
    {"word": "锦上添花", "pinyin": "jǐn shàng tiān huā", "explanation": "在锦上再绣花。比喻好上加好，美上添美。"},
    {"word": "画龙点睛", "pinyin": "huà lóng diǎn jīng", "explanation": "原形容梁代画家张僧繇作画的神妙。后比喻写文章或讲话时，在关键处用几句话点明实质，使内容生动有力。"},
    {"word": "点石成金", "pinyin": "diǎn shí chéng jīn", "explanation": "神话故事中仙人用手指一点使铁变成金子。比喻修改文章时稍稍改动原来的文字，就使它变得很出色。"},
    {"word": "妙笔生花", "pinyin": "miào bǐ shēng huā", "explanation": "比喻杰出的写作才能。"},
    {"word": "字字珠玑", "pinyin": "zì zì zhū jī", "explanation": "珠玑珠子。每个字都像珍珠一样。比喻说话、文章的词句十分优美。"},
    {"word": "掷地有声", "pinyin": "zhì dì yǒu shēng", "explanation": "金石落地发出的声音。比喻文章词藻优美，语言铿锵有力。"},
    {"word": "一语中的", "pinyin": "yī yǔ zhòng dì", "explanation": "的一句话就说中要害。形容说话精辟，一语道破。"},
    {"word": "一针见血", "pinyin": "yī zhēn jiàn xiě", "explanation": "比喻说话直截了当，切中要害。"},
    {"word": "入木三分", "pinyin": "rù mù sān fēn", "explanation": "相传王羲之在木板上写字，墨汁渗入木板有三分深。形容书法笔力刚劲有力，也比喻对文章或事物见解很深刻。"},
    {"word": "力透纸背", "pinyin": "lì tòu zhǐ bèi", "explanation": "透穿过。形容书法笔力遒劲。也形容诗文立意深刻，词语精练。"},
    {"word": "酣畅淋漓", "pinyin": "hān chàng lín lí", "explanation": "酣畅畅快；淋漓饱满畅快的样子。形容非常畅快。也形容文章、说话表达得充分、详尽。"},
    {"word": "淋漓尽致", "pinyin": "lín lí jìn zhì", "explanation": "淋漓形容湿淋淋往下滴；尽致达到极点。形容文章或说话表达得非常充分、透彻，或非常痛快。"},
    {"word": "博大精深", "pinyin": "bó dà jīng shēn", "explanation": "博广大，丰富。形容思想和学识广博高深。"},
    {"word": "源远流长", "pinyin": "yuán yuǎn liú cháng", "explanation": "源头很远，水流很长。比喻历史悠久。"},
    {"word": "厚积薄发", "pinyin": "hòu jī bó fā", "explanation": "厚积指大量地、充分地积蓄；薄发指少量地、慢慢地释放。多多积蓄，慢慢放出。形容只有准备充分才能办好事情。"},
    {"word": "潜移默化", "pinyin": "qián yí mò huà", "explanation": "潜暗中同，不见形迹；默不说话，没有声音。指人的思想或性格不知不觉受到感染、影响而发生了变化。"},
    {"word": "润物无声", "pinyin": "rùn wù wú shēng", "explanation": "本指初春的毛毛小雨落下无声无息。常用来形容教育者默默奉献，在不知不觉中影响他人。"},
    {"word": "春风化雨", "pinyin": "chūn fēng huà yǔ", "explanation": "化雨化生和养育。指适宜于草木生长的风雨。比喻良好的薰陶和教育。"},
    {"word": "循循善诱", "pinyin": "xún xún shàn yòu", "explanation": "循循有次序的样子；善善于；诱引导。指善于引导别人进行学习。"},
    {"word": "因材施教", "pinyin": "yīn cái shī jiào", "explanation": "因根据；材资质；施施教；教教育。指针对学习的人的志趣、能力等具体情况进行不同的教育。"},
    {"word": "诲人不倦", "pinyin": "huì rén bù juàn", "explanation": "诲教导。教导人特别耐心，从不厌倦。"},
    {"word": "言传身教", "pinyin": "yán chuán shēn jiào", "explanation": "言传用言语讲解传授；身教以行动示范。一面言语传授，一面行动示范。指用言行影响、教导别人。"},
    {"word": "身体力行", "pinyin": "shēn tǐ lì xíng", "explanation": "身亲自；体体验。亲身体验，努力实行。"},
    {"word": "以身作则", "pinyin": "yǐ shēn zuò zé", "explanation": "则准则，榜样。用自己的实际行动做榜样。"},
    {"word": "率先垂范", "pinyin": "shuài xiān chuí fàn", "explanation": "率先带头；垂范示范。带头给下级或晚辈做示范。"},
    {"word": "克己奉公", "pinyin": "kè jǐ fèng gōng", "explanation": "克己约束自己；奉公以公事为重。克服私欲，严格要求自己，一心为公。"},
    {"word": "大公无私", "pinyin": "dà gōng wú sī", "explanation": "指办事公正，没有私心。现多指从集体利益出发，毫无个人打算。"},
    {"word": "鞠躬尽瘁", "pinyin": "jū gōng jìn cuì", "explanation": "鞠躬弯着身子，表示恭敬谨慎；尽瘁竭尽劳苦。指恭敬谨慎，竭尽心力。"},
    {"word": "任劳任怨", "pinyin": "rèn láo rèn yuàn", "explanation": "任担当，经受。做事不辞劳苦，不怕别人埋怨。"},
    {"word": "兢兢业业", "pinyin": "jīng jīng yè yè", "explanation": "兢兢小心谨慎的样子；业业担心害怕的样子。形容做事谨慎、勤恳。"},
    {"word": "脚踏实地", "pinyin": "jiǎo tà shí dì", "explanation": "脚踏在坚实的土地上。比喻做事踏实，认真。"},
    {"word": "求真务实", "pinyin": "qiú zhēn wù shí", "explanation": "探求真理，注重实际。"},
    {"word": "开拓创新", "pinyin": "kāi tuò chuàng xīn", "explanation": "开拓开辟，扩展；创新创造新的。开辟扩展新领域，创造新事物。"},
    {"word": "锐意进取", "pinyin": "ruì yì jìn qǔ", "explanation": "锐意决心，意志坚决；进取努力向前。意志坚决地追求上进，下决心迎难而上。"},
    {"word": "奋发图强", "pinyin": "fèn fā tú qiáng", "explanation": "图谋求。振作精神，以求强盛。"},
    {"word": "励精图治", "pinyin": "lì jīng tú zhì", "explanation": "励奋勉；图设法；治治理好国家。振奋精神，想办法治理好国家。"},
    {"word": "众志成城", "pinyin": "zhòng zhì chéng chéng", "explanation": "万众一心，像坚固的城墙一样不可摧毁。比喻团结一致，力量无比强大。"},
    {"word": "同心协力", "pinyin": "tóng xīn xié lì", "explanation": "心思想；力力量。团结一致，共同努力。"},
    {"word": "齐心协力", "pinyin": "qí xīn xié lì", "explanation": "形容认识一致，共同努力。"},
    {"word": "和衷共济", "pinyin": "hé zhōng gòng jì", "explanation": "衷内心；济渡。大家一条心，共同渡过江河。比喻同心协力，克服困难。"},
    {"word": "风雨同舟", "pinyin": "fēng yǔ tóng zhōu", "explanation": "在狂风暴雨中同乘一条船，一起与风雨搏斗。比喻共同经历患难。"},
    {"word": "患难与共", "pinyin": "huàn nàn yǔ gòng", "explanation": "共同承担危险和困难。指彼此关系密切，利害一致。"},
    {"word": "休戚与共", "pinyin": "xiū qī yǔ gòng", "explanation": "休欢乐；戚忧愁。忧喜、祸福彼此共同承担。形容关系密切，利害相同。"},
    {"word": "荣辱与共", "pinyin": "róng rǔ yǔ gòng", "explanation": "光荣与耻辱共同分享与承担。"},
    {"word": "肝胆相照", "pinyin": "gān dǎn xiāng zhào", "explanation": "肝胆比喻真心诚意。比喻以真心相见。"},
    {"word": "推心置腹", "pinyin": "tuī xīn zhì fù", "explanation": "把赤诚的心交给人家。比喻真心待人。"},
    {"word": "心心相印", "pinyin": "xīn xīn xiāng yìn", "explanation": "心心彼此的心意；印符合。彼此的心意不用说出，就可以互相了解。形容彼此思想感情完全一致。"},
    {"word": "志同道合", "pinyin": "zhì tóng dào hé", "explanation": "志兴趣；道方向。志趣相同，意见一致。"},
    {"word": "情投意合", "pinyin": "qíng tóu yì hé", "explanation": "投相合。形容双方思想感情融洽，合得来。"},
    {"word": "莫逆之交", "pinyin": "mò nì zhī jiāo", "explanation": "莫逆没有抵触，感情融洽；交交往，友谊。指非常要好的朋友。"},
    {"word": "高山流水", "pinyin": "gāo shān liú shuǐ", "explanation": "比喻知己或知音。也比喻乐曲高妙。"},
    {"word": "知音难觅", "pinyin": "zhī yīn nán mì", "explanation": "知音了解自己特长的人。真正了解自己的人很难找到。"},
    {"word": "千里马常有，而伯乐不常有", "pinyin": "qiān lǐ mǎ cháng yǒu, ér bó lè bù cháng yǒu", "explanation": "千里马常有，但能识别千里马的伯乐却不常有。比喻人才常有，但能识才的人不常有。"},
    {"word": "居安思危", "pinyin": "jū ān sī wēi", "explanation": "居处于；思想。虽然处在平安的环境里，也想到有出现危险的可能。指随时有应付意外事件的思想准备。"},
    {"word": "未雨绸缪", "pinyin": "wèi yǔ chóu móu", "explanation": "绸缪紧密缠缚。天还没有下雨，先把门窗绑牢。比喻事先做好准备工作。"},
    {"word": "防患未然", "pinyin": "fáng huàn wèi rán", "explanation": "患灾祸；未然没有这样，指尚未形成。在灾祸尚未形成之前就加以防备。"},
    {"word": "有备无患", "pinyin": "yǒu bèi wú huàn", "explanation": "患祸患，灾难。事先有准备，就可以避免祸患。"},
    {"word": "防微杜渐", "pinyin": "fáng wēi dù jiàn", "explanation": "微微小；杜堵住；渐指事物的开端。在坏思想、坏事或错误刚冒头时，就加以防止、杜绝，不让其发展。"},
    {"word": "亡羊补牢", "pinyin": "wáng yáng bǔ láo", "explanation": "亡逃亡，丢失；牢关牲口的圈。羊逃跑了再去修补羊圈，还不算晚。比喻出了问题以后想办法补救，可以防止继续受损失。"},
    {"word": "前车之鉴", "pinyin": "qián chē zhī jiàn", "explanation": "鉴镜子，引申为教训。前面车子翻倒的教训。比喻先前的失败，可以做为以后的教训。"},
    {"word": "吃一堑长一智", "pinyin": "chī yī qiàn zhǎng yī zhì", "explanation": "堑壕沟，比喻挫折。受一次挫折，增长一分见识。"},
    {"word": "温故知新", "pinyin": "wēn gù zhī xīn", "explanation": "温温习；故旧的。温习旧的知识，得到新的理解和体会。也指回忆过去，能更好地认识现在。"},
    {"word": "举一反三", "pinyin": "jǔ yī fǎn sān", "explanation": "反类推。列举出一个，就可以由此类推而知道其他三个。比喻从一件事情类推而知道其他更多的事情。"},
    {"word": "触类旁通", "pinyin": "chù lèi páng tōng", "explanation": "触类接触某一方面的事物；旁通相互贯通。掌握了某一事物的知识或规律，就能推知同类的事物。"},
    {"word": "融会贯通", "pinyin": "róng huì guàn tōng", "explanation": "融会融合领会；贯通贯穿前后。把各方面的知识和道理融化汇合，得到全面透彻的理解。"},
    {"word": "豁然开朗", "pinyin": "huò rán kāi lǎng", "explanation": "豁然形容开阔；开朗开阔明亮。从黑暗狭窄变得宽敞明亮。比喻突然领悟了一个道理。"},
    {"word": "茅塞顿开", "pinyin": "máo sè dùn kāi", "explanation": "茅塞喻人思路闭塞或不懂事；顿立刻。原来心里好像有茅草堵塞着，现在忽然打开了。形容思想忽然开窍，立刻明白了某个道理。"},
    {"word": "恍然大悟", "pinyin": "huǎng rán dà wù", "explanation": "恍然猛然清醒的样子；悟心里明白。形容一下子明白过来。"},
    {"word": "醍醐灌顶", "pinyin": "tí hú guàn dǐng", "explanation": "醍醐酥酪上凝聚的油。用纯酥油浇到头上。佛教指灌输智慧，使人彻底觉悟。比喻听了高明的意见使人受到很大启发。"},
    {"word": "振聋发聩", "pinyin": "zhèn lóng fā kuì", "explanation": "聩天生耳聋，引申为不明事理。声音很大，使耳聋的人也听得见。比喻用语言文字唤醒糊涂麻木的人。"},
    {"word": "发人深省", "pinyin": "fā rén shēn xǐng", "explanation": "发启发；省醒悟。启发人深刻思考，有所醒悟。"},
    {"word": "耐人寻味", "pinyin": "nài rén xún wèi", "explanation": "耐禁得起；寻味探索体味。意味深长，值得人仔细体会琢磨。"},
    {"word": "意味深长", "pinyin": "yì wèi shēn cháng", "explanation": "意味情调，趣味。意思含蓄深远，耐人寻味。"},
    {"word": "言简意赅", "pinyin": "yán jiǎn yì gāi", "explanation": "赅完备。话不多，但意思都有了。形容说话写文章简明扼要。"},
    {"word": "微言大义", "pinyin": "wēi yán dà yì", "explanation": "微言精当而含义深远的话；大义本指经书的要义。包含在精微语言里的深刻的道理。"},
    {"word": "深入浅出", "pinyin": "shēn rù qiǎn chū", "explanation": "指言论或文章的观点主题意义深刻，但在语言文字的表达方式上却浅显易懂。"},
    {"word": "雅俗共赏", "pinyin": "yǎ sú gòng shǎng", "explanation": "形容某些文艺作品既优美，又通俗，各种文化程度的人都能够欣赏。"},
    {"word": "喜闻乐见", "pinyin": "xǐ wén lè jiàn", "explanation": "喜欢听，乐意看。形容很受欢迎。"},
    {"word": "脍炙人口", "pinyin": "kuài zhì rén kǒu", "explanation": "脍切细的肉；炙烤熟的肉。指美味的食品人人爱吃。比喻好的诗文受到人们的称赞和传颂。"},
    {"word": "家喻户晓", "pinyin": "jiā yù hù xiǎo", "explanation": "喻明白；晓知道。家家户户都知道。形容人所共知。"},
    {"word": "妇孺皆知", "pinyin": "fù rú jiē zhī", "explanation": "孺小孩子。妇女和小孩子都知道。形容事情传播得很广，大家都知道。"},
    {"word": "老少皆宜", "pinyin": "lǎo shào jiē yí", "explanation": "老人和少年都合适。形容适合各种年龄的人。"},
    {"word": "生生不息", "pinyin": "shēng shēng bù xī", "explanation": "生生中国哲学术语，指变化和新生事物的发生；不息没有终止。不断地生长、繁殖。"},
    {"word": "绵延不绝", "pinyin": "mián yán bù jué", "explanation": "绵延延续不断的样子。形容连续不断，从不中断。"},
    {"word": "薪火相传", "pinyin": "xīn huǒ xiāng chuán", "explanation": "古时候比喻形骸有尽而精神不灭；后人用来比喻学问和技艺代代相传。"},
    {"word": "一脉相承", "pinyin": "yī mài xiāng chéng", "explanation": "从同一血脉、派别世代相承流传下来。比喻某种思想、行为或学说之间有继承关系。"},
    {"word": "薪尽火传", "pinyin": "xīn jìn huǒ chuán", "explanation": "薪柴。柴虽烧尽，火种仍留传。比喻思想、学术、技艺等世代相传。"},
    {"word": "生生不已", "pinyin": "shēng shēng bù yǐ", "explanation": "生生中国哲学术语，指变化和新生事物的发生；不已没有终止。形容一切事物新陈代谢，永无停止。"},
    {"word": "历久弥新", "pinyin": "lì jiǔ mí xīn", "explanation": "弥更加。经历长久的时间反而更加鲜活，更有活力。"},
    {"word": "经久不衰", "pinyin": "jīng jiǔ bù shuāi", "explanation": "经过很长时间而不衰退。形容影响深远，经得起时间考验。"},
    {"word": "长盛不衰", "pinyin": "cháng shèng bù shuāi", "explanation": "长久兴盛而不衰败。形容某事物一直保持旺盛的势头。"},
    {"word": "千古流传", "pinyin": "qiān gǔ liú chuán", "explanation": "千古久远的年代。经历久远的年代而流传下来。"},
    {"word": "举世瞩目", "pinyin": "jǔ shì zhǔ mù", "explanation": "瞩目注视。全世界的人都注视着。"},
    {"word": "举足轻重", "pinyin": "jǔ zú qīng zhòng", "explanation": "只要脚移动一下，就会影响两边的轻重。指处于重要地位，一举一动都足以影响全局。"},
    {"word": "不可估量", "pinyin": "bù kě gū liàng", "explanation": "估量估计。不可以估计。形容数量大或程度重。"},
    {"word": "举世无双", "pinyin": "jǔ shì wú shuāng", "explanation": "全世界找不到第二个。"},
    {"word": "独一无二", "pinyin": "dú yī wú èr", "explanation": "没有相同的或没有可以相比的。"},
    {"word": "无与伦比", "pinyin": "wú yǔ lún bǐ", "explanation": "伦比类比，匹敌。指事物非常完美，没有能跟它相比的。"},
    {"word": "空前绝后", "pinyin": "kōng qián jué hòu", "explanation": "从前没有过，今后也不会再有。夸张性地形容独一无二。"},
    {"word": "史无前例", "pinyin": "shǐ wú qián lì", "explanation": "历史上从来没有过的事。指前所未有。"},
    {"word": "前所未有", "pinyin": "qián suǒ wèi yǒu", "explanation": "历史上从来没有过。"},
    {"word": "开天辟地", "pinyin": "kāi tiān pì dì", "explanation": "古代神话盘古氏开辟天地。比喻有史以来第一次。"},
    {"word": "筚路蓝缕", "pinyin": "bì lù lán lǚ", "explanation": "筚路柴车；蓝缕破衣服。驾着柴车，穿着破衣服去开辟山林。形容创业的艰苦。"},
    {"word": "栉风沐雨", "pinyin": "zhì fēng mù yǔ", "explanation": "栉梳头发；沐洗头发。风梳发，雨洗头。形容人经常在外面不避风雨地辛苦奔波。"},
    {"word": "披星戴月", "pinyin": "pī xīng dài yuè", "explanation": "身披星星，头戴月亮。形容连夜奔波或早出晚归，十分辛苦。"},
    {"word": "风雨无阻", "pinyin": "fēng yǔ wú zǔ", "explanation": "不受刮风下雨的阻碍。指预先约好的事情，一定按期进行。"},
    {"word": "夜以继日", "pinyin": "yè yǐ jì rì", "explanation": "用夜晚的时间接上白天，日夜不停。"},
    {"word": "争分夺秒", "pinyin": "zhēng fēn duó miǎo", "explanation": "一分一秒也不放过。形容充分利用时间。"},
    {"word": "时不我待", "pinyin": "shí bù wǒ dài", "explanation": "时间不会等待我们。指要抓紧时间。"},
    {"word": "只争朝夕", "pinyin": "zhǐ zhēng zhāo xī", "explanation": "朝夕早晨和晚上。形容时间短暂。比喻抓紧时间，力争在最短的时间内达到目的。"},
    {"word": "分秒必争", "pinyin": "fēn miǎo bì zhēng", "explanation": "一分一秒也一定要争取。形容抓紧时间。"},
    {"word": "刻不容缓", "pinyin": "kè bù róng huǎn", "explanation": "刻片刻；容容许；缓延缓。指形势紧迫，一刻也不允许拖延。"},
    {"word": "迫在眉睫", "pinyin": "pò zài méi jié", "explanation": "形容事情已到眼前，情势十分紧迫。"},
    {"word": "当务之急", "pinyin": "dāng wù zhī jí", "explanation": "当务指应当办理的事。当前任务中最急切要办的事。"},
    {"word": "燃眉之急", "pinyin": "rán méi zhī jí", "explanation": "燃烧。火烧眉毛那样紧急。形容事情非常急迫。"},
    {"word": "义不容辞", "pinyin": "yì bù róng cí", "explanation": "容允许；辞推托。道义上不允许推辞。"},
    {"word": "责无旁贷", "pinyin": "zé wú páng dài", "explanation": "贷推卸。自己的责任，不能推卸给别人。"},
    {"word": "当仁不让", "pinyin": "dāng rén bù ràng", "explanation": "原指以仁为任，无所谦让。后指遇到应该做的事就积极主动去做，不推让。"},
    {"word": "义无反顾", "pinyin": "yì wú fǎn gù", "explanation": "义道义；反顾向后看。从道义上只有勇往直前，不能犹豫回顾。"},
    {"word": "勇往直前", "pinyin": "yǒng wǎng zhí qián", "explanation": "勇敢地一直向前进。"},
    {"word": "奋不顾身", "pinyin": "fèn bù gù shēn", "explanation": "奋勇向前，不考虑个人安危。"},
    {"word": "赴汤蹈火", "pinyin": "fù tāng dǎo huǒ", "explanation": "赴走往；汤热水；蹈踩。沸水敢蹚，烈火敢踏。比喻不避艰险，奋不顾身。"},
    {"word": "万死不辞", "pinyin": "wàn sǐ bù cí", "explanation": "万死死一万次，形容冒生命危险。辞推辞。表示愿意拼死效劳。"},
    {"word": "视死如归", "pinyin": "shì sǐ rú guī", "explanation": "把死看得像回家一样平常。形容不怕牺牲。"},
    {"word": "大义凛然", "pinyin": "dà yì lǐn rán", "explanation": "大义正义；凛然严肃、或敬畏的样子。坚持正义而不可侵犯的样子。"},
    {"word": "浩然正气", "pinyin": "hào rán zhèng qì", "explanation": "正大刚直的气势。"},
    {"word": "铁骨铮铮", "pinyin": "tiě gǔ zhēng zhēng", "explanation": "铮铮金属相击的声音。形容人刚正不阿，有骨气。"},
    {"word": "刚正不阿", "pinyin": "gāng zhèng bù ē", "explanation": "阿迎合，偏袒。刚强正直，不逢迎，不偏私。"},
    {"word": "光明磊落", "pinyin": "guāng míng lěi luò", "explanation": "磊落心地光明坦白。胸怀坦白，正大光明。"},
    {"word": "堂堂正正", "pinyin": "táng táng zhèng zhèng", "explanation": "堂堂盛大的样子；正正整齐的样子。原形容强大整齐的样子，现也形容光明正大。也形容身材威武，仪表出众。"},
    {"word": "坦坦荡荡", "pinyin": "tǎn tǎn dàng dàng", "explanation": "形容心胸开阔，光明正大。"},
    {"word": "问心无愧", "pinyin": "wèn xīn wú kuì", "explanation": "问心问问自己。扪心自问，毫无愧色。"},
    {"word": "仰不愧天", "pinyin": "yǎng bù kuì tiān", "explanation": "抬头仰望，对天无愧。指没有做过坏事，问心无愧。"},
    {"word": "俯仰无愧", "pinyin": "fǔ yǎng wú kuì", "explanation": "比喻没有做坏事，不论面对什么人都问心无愧。"},
    {"word": "高风亮节", "pinyin": "gāo fēng liàng jié", "explanation": "高风高尚的品格；亮节坚贞的节操。形容道德和行为都很高尚。"},
    {"word": "德高望重", "pinyin": "dé gāo wàng zhòng", "explanation": "德品德；望声望。道德高尚，名望很大。"},
    {"word": "两袖清风", "pinyin": "liǎng xiù qīng fēng", "explanation": "衣袖中除清风外，别无所有。比喻做官廉洁。也比喻穷得一无所有。"},
    {"word": "一尘不染", "pinyin": "yī chén bù rǎn", "explanation": "原指佛教徒修行时，排除物欲，保持心地洁净。现泛指丝毫不受坏习惯、坏风气的影响。也用来形容非常清洁、干净。"},
    {"word": "冰清玉洁", "pinyin": "bīng qīng yù jié", "explanation": "像冰那样清澈，像玉那样洁白。形容人品高尚，操行纯洁。"},
    {"word": "洁身自好", "pinyin": "jié shēn zì hào", "explanation": "保持自己纯洁，不同流合污。也指怕招惹是非，只顾自己好，不关心公众事情。"},
    {"word": "虚怀若谷", "pinyin": "xū huái ruò gǔ", "explanation": "虚谦虚；谷山谷。胸怀像山谷一样深广。形容十分谦虚，能容纳别人的意见。"},
    {"word": "谦谦君子", "pinyin": "qiān qiān jūn zǐ", "explanation": "指谦虚而严格要求自己的人。"},
    {"word": "不耻下问", "pinyin": "bù chǐ xià wèn", "explanation": "乐于向学问或地位比自己低的人学习，而不觉得不好意思。"},
    {"word": "学而不厌", "pinyin": "xué ér bù yàn", "explanation": "厌满足。学习总感到不满足。形容好学。"},
    {"word": "不骄不躁", "pinyin": "bù jiāo bù zào", "explanation": "不骄傲，不急躁。形容人态度沉着谦逊。"},
    {"word": "戒骄戒躁", "pinyin": "jiè jiāo jiè zào", "explanation": "戒防备；躁急躁。警惕产生骄傲和急躁的情绪。"},
    {"word": "谦虚谨慎", "pinyin": "qiān xū jǐn shèn", "explanation": "谦虚虚心；谨慎慎重。形容人虚心礼让，小心谨慎。"},
    {"word": "慎终如始", "pinyin": "shèn zhōng rú shǐ", "explanation": "慎谨慎。谨慎收尾，如同开始时一样。指始终要谨慎从事。"},
    {"word": "善始善终", "pinyin": "shàn shǐ shàn zhōng", "explanation": "做事情有好的开头，也有好的结尾。形容办事认真。"},
    {"word": "有始有终", "pinyin": "yǒu shǐ yǒu zhōng", "explanation": "有开头也有收尾。指做事能坚持到底。"},
    {"word": "始终如一", "pinyin": "shǐ zhōng rú yī", "explanation": "始开始；终结束。自始自终一个样子。指能坚持，不间断。"},
    {"word": "一如既往", "pinyin": "yī rú jì wǎng", "explanation": "一完全；既往从前，已往。指态度没有变化，完全像从前一样。"},
    {"word": "初心不改", "pinyin": "chū xīn bù gǎi", "explanation": "最初的心意没有改变。形容坚持最初的信念和理想。"},
    {"word": "矢志不渝", "pinyin": "shǐ zhì bù yú", "explanation": "矢誓；渝改变。立下志愿决不改变。"},
    {"word": "忠贞不渝", "pinyin": "zhōng zhēn bù yú", "explanation": "忠忠诚；贞有操守；渝改变。忠诚坚定，永不改变。"},
    {"word": "坚贞不屈", "pinyin": "jiān zhēn bù qū", "explanation": "坚坚定；贞有节操；屈屈服、低头。意志坚定，决不屈服。"},
    {"word": "宁死不屈", "pinyin": "nìng sǐ bù qū", "explanation": "宁愿死也不屈服。"},
    {"word": "威武不屈", "pinyin": "wēi wǔ bù qū", "explanation": "威武权势，武力；屈屈服。强暴的压力不能使之屈服。表示坚贞顽强。"},
    {"word": "贫贱不移", "pinyin": "pín jiàn bù yí", "explanation": "移改变。不因生活贫困、社会地位低下而改变自己的志向。"},
    {"word": "富贵不淫", "pinyin": "fù guì bù yín", "explanation": "淫惑乱。不因有钱有势而惑乱。"},
    {"word": "宠辱不惊", "pinyin": "chǒng rǔ bù jīng", "explanation": "宠宠爱；辱侮辱。受宠受辱都不在乎。指不因个人得失而动心。"},
    {"word": "不卑不亢", "pinyin": "bù bēi bù kàng", "explanation": "卑低、自卑；亢高傲。指对人有恰当的分寸，既不低声下气，也不傲慢自大。"},
    {"word": "淡泊名利", "pinyin": "dàn bó míng lì", "explanation": "淡泊不追求名利。不追求名和利。"},
    {"word": "宁静致远", "pinyin": "níng jìng zhì yuǎn", "explanation": "宁静心情平稳安静；致远实现远大目标。平稳静谧心态，不为杂念所左右，静思反省，才能实现远大的目标。"},
    {"word": "厚德载物", "pinyin": "hòu dé zài wù", "explanation": "厚德以深厚的德泽育人利物。旧指道德高尚者能承担重大任务。"},
    {"word": "上善若水", "pinyin": "shàng shàn ruò shuǐ", "explanation": "最高境界的善行就像水的品性一样，泽被万物而不争名利。"},
    {"word": "海纳百川", "pinyin": "hǎi nà bǎi chuān", "explanation": "纳容纳。大海能容纳无数江河水。形容胸怀宽广，能包容一切。"},
    {"word": "有容乃大", "pinyin": "yǒu róng nǎi dà", "explanation": "容宽容。只有宽容大度，才能胸怀宽广。"},
    {"word": "兼收并蓄", "pinyin": "jiān shōu bìng xù", "explanation": "收收罗；蓄储藏。把不同内容、不同性质的东西收下来，保存起来。"},
    {"word": "博采众长", "pinyin": "bó cǎi zhòng cháng", "explanation": "博广泛；采采纳；长长处。广泛采纳众人的长处。"},
    {"word": "取长补短", "pinyin": "qǔ cháng bǔ duǎn", "explanation": "吸取别人的长处，来弥补自己的不足。"},
    {"word": "集思广益", "pinyin": "jí sī guǎng yì", "explanation": "集集中；思思考，意见；广扩大。指集中群众的智慧，广泛吸收有益的意见。"},
    {"word": "群策群力", "pinyin": "qún cè qún lì", "explanation": "群大家；策谋划；力力量。指发挥集体的作用，大家一起来想办法，贡献力量。"},
    {"word": "广开言路", "pinyin": "guǎng kāi yán lù", "explanation": "广广泛；言路进言的道路。指尽量给下面创造发表意见的条件。"},
    {"word": "从善如流", "pinyin": "cóng shàn rú liú", "explanation": "从听从；善好的；如流好像流水向下。形容能迅速地接受别人的好意见。"},
    {"word": "择善而从", "pinyin": "zé shàn ér cóng", "explanation": "从跟随。指选择好的方法、意见去遵从。"},
    {"word": "见贤思齐", "pinyin": "jiàn xián sī qí", "explanation": "贤德才兼备的人；齐相等。见到德才兼备的人就想赶上他。"},
    {"word": "三人行必有我师", "pinyin": "sān rén xíng bì yǒu wǒ shī", "explanation": "三个人一起走路，其中必定有可以作为我的老师的人。指应该虚心向别人学习。"},
    {"word": "学无止境", "pinyin": "xué wú zhǐ jìng", "explanation": "指学业上是没有尽头的，应奋进不息。"},
    {"word": "活到老学到老", "pinyin": "huó dào lǎo xué dào lǎo", "explanation": "指人一辈子都要学习。形容勤学不倦。"},
    {"word": "温故而知新", "pinyin": "wēn gù ér zhī xīn", "explanation": "温习旧的知识，能够得到新的理解和体会。"},
    {"word": "学以致用", "pinyin": "xué yǐ zhì yòng", "explanation": "为了实际应用而学习。"},
    {"word": "知行合一", "pinyin": "zhī xíng hé yī", "explanation": "认识事物的道理与在现实中运用此道理是密不可分的。"},
    {"word": "身体力行", "pinyin": "shēn tǐ lì xíng", "explanation": "身亲自；体体验。亲身体验，努力实行。"},
    {"word": "实事求是", "pinyin": "shí shì qiú shì", "explanation": "指从实际对象出发，探求事物的内部联系及其发展的规律性，认识事物的本质。"},
    {"word": "与时俱进", "pinyin": "yǔ shí jù jìn", "explanation": "随着时间的推移而不断发展、前进。"},
    {"word": "守正创新", "pinyin": "shǒu zhèng chuàng xīn", "explanation": "坚守正道，开拓创新。指在坚持基本原则的基础上进行创新。"},
    {"word": "继往开来", "pinyin": "jì wǎng kāi lái", "explanation": "继继承；开开辟。继承前人的事业，开辟未来的道路。"}
]
